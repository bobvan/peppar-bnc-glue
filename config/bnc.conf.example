# BNC headless config template for ptpmon.
#
# Operator copies this to config/bnc.conf (gitignored) on each host
# and fills in NTRIP credentials, then BNC reads via:
#   bnc --nw --conf /home/bob/peppar-bnc-glue/config/bnc.conf
#
# Format: BNC's QSettings .ini.  Section + key = value lines.
# Keys are documented under `bnc --help` (look for "Streams Panel
# keys", "PPP Client Panel 1 keys", etc.).

[BNC]
# General
logFile=/home/bob/peppar-bnc-glue/log/bnc.log

# Required for headless: BNC's GUI starts streams + PPP only when
# the operator clicks Start.  In --nw mode we need autoStart=2 (yes)
# or BNC exits ~immediately with code 3 ("nothing to do").
autoStart=2

# Streams Panel: list of NTRIP mounts BNC pulls.  Format per element:
#   //USER:PASS@HOST:PORT/MOUNT FORMAT COUNTRY LAT LON nmea NTRIPVER
# Multiple elements separated by ";".
#
# Three streams:
#   F9T_PTPMON  — local rover, our NTRIP caster on loopback (no auth, NTRIP/1)
#   SSRA00CNE0  — CNES corrections, products.igs-ip.net (NTRIP/2 over TLS)
#   BCEP00BKG0  — broadcast eph, ntrip.data.gnss.ga.gov.au (NTRIP/2 over TLS)
#
# Replace USER and PASS with credentials from /home/bob/peppar-fix/
# ntrip-cnes.conf and /home/bob/peppar-fix/ntrip.conf respectively.
#
# IMPORTANT: the value MUST be wrapped in double quotes.  BNC's
# QSettings .ini parser treats unquoted ";" as a comment-start
# character, which silently truncates mountPoints after the first
# entry — confirmed by "Configuration read: ..., 1 stream(s)" in
# bnc.log when the quotes were missing.
mountPoints="//:@127.0.0.1:2102/F9T_PTPMON RTCM_3.3 USA 38.00 -122.00 no 1;//USER:PASS@products.igs-ip.net:443/SSRA00CNE0 RTCM_3.3 FRA 48.00 2.00 no 2s;//USER:PASS@ntrip.data.gnss.ga.gov.au:443/BCEP00BKG0 RTCM_3.3 AUS -27.00 153.00 no 2s"

# PPP Client Panel 1
PPP/dataSource=Real-Time Streams
PPP/corrMount=SSRA00CNE0
PPP/logPath=/home/bob/peppar-bnc-glue/log/

# PPP Client Panel 2 — signal combinations for F9T-PTP (L2-only):
#   GPS L1CA + L2CL  → G:1&C  G:2&L
#   GAL E1   + E5b   → E:1&C  E:7&Q
#   BDS B1   + B2I   → C:2&I  C:7&I
#
# Station table format per element:
#   MOUNT,σdN(mm),σdE(mm),σdU(mm),σpN(mm),σpE(mm),σpU(mm),σTropo(m),Qtropo,port,signals
PPP/staTable="F9T_PTPMON,100.0,100.0,100.0,100.0,100.0,100.0,0.1,3e-6,0,G:1&C G:2&L E:1&C E:7&Q C:2&I C:7&I"

# Linear combinations: P3&L3 = ionosphere-free code+phase
PPP/lcGPS=P3&L3
PPP/lcGalileo=P3&L3
PPP/lcBDS=P3&L3
PPP/lcGLONASS=no

# Default sigmas (meters)
PPP/sigmaC1=2.0
PPP/sigmaL1=0.01
PPP/maxResC1=4.0
PPP/maxResL1=0.04
PPP/eleWgtCode=2
PPP/eleWgtPhase=2

# Convergence / wait
PPP/corrWaitTime=5

# Output: NMEA log per epoch (BNC writes <staid>.nmea + <staid>.ppp under logPath)
PPP/nmeaPath=/home/bob/peppar-bnc-glue/log/
